# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGO_DB_NAME=lottery_system

# JWT
SECRET_KEY=your-secret-key-change-in-production
JWT_EXPIRE_MINUTES=30

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# M-Pesa Daraja API — Production (https://developer.safaricom.co.ke)
# Use your production credentials from the Daraja portal
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_BUSINESS_SHORT_CODE=4561783
MPESA_PASSKEY=
MPESA_BASE_URL=https://api.safaricom.co.ke
# till = Buy Goods (Lipa Na M-Pesa) | paybill = PayBill
MPESA_ACCOUNT_TYPE=till
# Public HTTPS URLs — M-Pesa must reach these. Use ngrok for local testing.
MPESA_CALLBACK_URL=https://yourdomain.com/api/webhooks/mpesa/stk-callback
MPESA_C2B_CONFIRMATION_URL=https://yourdomain.com/api/webhooks/mpesa/c2b
MPESA_C2B_VALIDATION_URL=https://yourdomain.com/api/webhooks/mpesa/c2b/validate
