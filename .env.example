# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGO_DB_NAME=lottery_system

# JWT
SECRET_KEY=your-secret-key-change-in-production
JWT_EXPIRE_MINUTES=30

# CORS — include deployment URL (http + https)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://l-gain-v1.payl.to,https://l-gain-v1.payl.to

# M-Pesa Daraja API — Production (https://developer.safaricom.co.ke)
# Use your production credentials from the Daraja portal
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_BUSINESS_SHORT_CODE=4561783
MPESA_PASSKEY=
MPESA_BASE_URL=https://api.safaricom.co.ke
# till = Buy Goods (Lipa Na M-Pesa) | paybill = PayBill
MPESA_ACCOUNT_TYPE=till
# Public HTTPS URLs — M-Pesa requires HTTPS. Deployment: l-gain-v1.payl.to
# Daraja = M-Pesa API. Do NOT use "mpesa" in URLs (Safaricom rejects it)
MPESA_CALLBACK_URL=https://l-gain-v1.payl.to/api/webhooks/daraja/stk-callback
MPESA_C2B_CONFIRMATION_URL=https://l-gain-v1.payl.to/api/webhooks/daraja/c2b
MPESA_C2B_VALIDATION_URL=https://l-gain-v1.payl.to/api/webhooks/daraja/c2b/validate
